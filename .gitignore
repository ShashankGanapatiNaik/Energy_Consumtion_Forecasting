# ═══════════════════════════════════════
# EnergyIQ — Smart Energy Forecasting
# .gitignore
# ═══════════════════════════════════════

# ───────────────────────────────────────
# Environment Variables (NEVER commit)
# ───────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
backend/.env
frontend/.env

# ───────────────────────────────────────
# Python / Backend
# ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
venv/
env/
.venv/
.env/
ENV/
backend/venv/
backend/env/

# ML model artifacts (large binary files)
*.pkl
*.pickle
*.h5
*.keras
*.pt
*.pth
*.joblib
backend/ml/saved_models/
backend/models/saved/

# TensorFlow / Keras
*.tfevents.*
logs/
tf_logs/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# mypy / type checking
.mypy_cache/
.dmypy.json

# ───────────────────────────────────────
# Node / Frontend
# ───────────────────────────────────────
node_modules/
frontend/node_modules/

# React build output
frontend/build/
build/

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json
yarn.lock

# ───────────────────────────────────────
# Database
# ───────────────────────────────────────
*.db
*.sqlite
*.sqlite3
dump.rdb
mongodump/
data/db/

# ───────────────────────────────────────
# Uploads / User Data
# ───────────────────────────────────────
backend/uploads/
uploads/
*.csv
!sample_dataset.csv

# ───────────────────────────────────────
# OS & Editor
# ───────────────────────────────────────

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains / PyCharm
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*.swn
*~
\#*\#
.#*

